# MongoDB
MONGO_URI=mongodb://user:pass@host:27017/uza?authSource=admin
# Pool / timeout tuning (remote Mongo — reduces burst load and long hangs)
MONGO_MAX_POOL_SIZE=15
MONGO_MIN_POOL_SIZE=2
MONGO_SERVER_SELECTION_TIMEOUT_MS=10000
MONGO_CONNECT_TIMEOUT_MS=10000
MONGO_SOCKET_TIMEOUT_MS=45000
MONGO_HEARTBEAT_FREQUENCY_MS=10000
MONGO_MAX_IDLE_TIME_MS=60000
MONGO_RECONNECT_DELAY_MS=3000
EXCHANGE_RATE_CACHE_TTL_MS=120000
CATEGORY_THUMBNAIL_CONCURRENCY=4
PORT=1302

# 1688 Open Platform (products / suppliers / trade / logistics)
ALIBABA_BASE_APP_URL=http://gw.open.1688.com/openapi/
ALIBABA_APP_KEY=
ALIBABA_APP_SECRET=
ALIBABA_AUTH_TOKEN=

# Trade relay — creates 1688 cross-border orders on UZA checkout
ALIBABA_TRADE_ENABLED=true
ALIBABA_TRADE_FLOW=general
ALIBABA_TRADE_ISV_BIZ_TYPE=cross

# China consolidation warehouse address (1688 ships here first)
ALIBABA_TRADE_WAREHOUSE_PROVINCE=浙江省
ALIBABA_TRADE_WAREHOUSE_CITY=杭州市
ALIBABA_TRADE_WAREHOUSE_AREA=滨江区
ALIBABA_TRADE_WAREHOUSE_ADDRESS=网商路699号
ALIBABA_TRADE_WAREHOUSE_CONTACT=UZA Bulk Warehouse
ALIBABA_TRADE_WAREHOUSE_MOBILE=13800000000
ALIBABA_TRADE_WAREHOUSE_DISTRICT_CODE=330108

# OAuth (optional — auto-refresh token instead of manual ALIBABA_AUTH_TOKEN)
ALIBABA_OAUTH_ENABLED=false
ALIBABA_OAUTH_REDIRECT_URI=https://your-api.example.com/api/v1/alibaba/oauth/callback

# Background jobs
ALIBABA_LOGISTICS_JOB_ENABLED=true
ALIBABA_LOGISTICS_POLL_HOURS=6
ALIBABA_CATALOG_SYNC_JOB_ENABLED=true
ALIBABA_CATALOG_SYNC_INTERVAL_HOURS=24

# Elasticsearch product index — incremental sync after 1688 catalog updates
ES_PRODUCT_SYNC_JOB_ENABLED=true
# Optional periodic catch-up (0 = off; sync still runs after catalog job)
ES_PRODUCT_SYNC_INTERVAL_HOURS=0

# Alibaba Cloud Model Studio (DashScope) — OpenAI-compatible LLM API
# Get API key: Model Studio console → API Key management
# Workspace ID = owner account / workspace id shown in console (Singapore/HK/Frankfurt regions)
DASHSCOPE_API_KEY=
DASHSCOPE_WORKSPACE_ID=
# singapore | us | beijing | hongkong | frankfurt | singapore_workspace
DASHSCOPE_REGION=singapore
# International Singapore (typical for sk- keys from Model Studio):
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Workspace MaaS URL only if shown in your console:
# DASHSCOPE_BASE_URL=https://YOUR_WORKSPACE_ID.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1
# Use qwen-vl-plus if qwen-plus is not authorized in Model Studio console
DASHSCOPE_MODEL=qwen-vl-plus
DASHSCOPE_VL_MODEL=qwen-vl-plus
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v3
DASHSCOPE_EMBEDDING_DIMENSIONS=1024
DASHSCOPE_TIMEOUT_MS=60000
# Auto-apply AI without frontend (default: true when API key is set)
DASHSCOPE_AUTO_SMART_LISTING=true
DASHSCOPE_AUTO_RECOMMENDATIONS=true
DASHSCOPE_RECOMMENDATION_BOOST_WEIGHT=4
DASHSCOPE_AI_SEARCH=true
DASHSCOPE_AI_TEXT_SEARCH=true
DASHSCOPE_AI_IMAGE_SEARCH=true
DASHSCOPE_SMART_IMAGE_SEARCH=true
# Buyer-side vector search tuning
SEARCH_EMBEDDING_BOOST=true
VECTOR_SEARCH_CANDIDATE_LIMIT=800
CNY_PER_USD=7.2
# Async WAN image enhancement (background catalog upgrade)
DASHSCOPE_WAN_ENHANCE=false

# Personalized Recommendations Engine (Behavioral AI)
RECOMMENDATION_ENGINE_ENABLED=true
RECOMMENDATION_CACHE_TTL_MS=900000
RECOMMENDATION_CROSS_SELL_TTL_MS=300000
RECOMMENDATION_EMAIL_TTL_MS=604800000
RECOMMENDATION_AB_TEST=true
RECOMMENDATION_AB_TREATMENT_RATIO=0.5
DASHSCOPE_RANKING_MODEL=qwen-turbo
ROCKETMQ_ENABLED=false
ROCKETMQ_WEBHOOK_URL=

# AI Buyer Assistant (RAG chatbot)
BUYER_ASSISTANT_ENABLED=true
BUYER_ASSISTANT_RAG_TOP_K=5
DASHSCOPE_ASSISTANT_MODEL=qwen-plus

# Visual image search (pHash compare uploaded image vs catalog photos)
# pip install -r scripts/requirements-image-search.txt
LOCAL_IMAGE_SEARCH_ENABLED=true
LOCAL_IMAGE_SEARCH_LIVE_ENABLED=true
LOCAL_IMAGE_SEARCH_BUILD_LIMIT=0
LOCAL_IMAGE_SEARCH_IMAGES_PER_PRODUCT=4
LOCAL_IMAGE_SEARCH_MIN_SIMILARITY=0.38
LOCAL_IMAGE_SEARCH_LIVE_CANDIDATES=120
# Build index after deploy or catalog sync: npm run image-index:build

# 1688 marketplace image search (requires Alibaba Open Platform credentials)
# IMAGE_SEARCH_INCLUDE_1688=true — fallback when catalog results are thin
# IMAGE_SEARCH_1688_ENHANCED=true — parallel multi-API bundle (imageQuery + domestic similar + sameOffers)
IMAGE_SEARCH_INCLUDE_1688=false
IMAGE_SEARCH_1688_ENHANCED=true
IMAGE_SEARCH_1688_ENHANCED_BUDGET_MS=35000
IMAGE_SEARCH_ALIBABA_BUDGET_MS=18000

# Live catalog phrase hints during image search (ES queries per search — no offline build)
CATALOG_VOCAB_LIVE_ENABLED=true
CATALOG_VOCAB_LIVE_MAX_TOKENS=3
# Visual-first image search: match uploaded photo to catalog images; VL keywords only when visual matches are thin
IMAGE_SEARCH_VISUAL_FIRST=true
IMAGE_SEARCH_VISUAL_MIN_RESULTS=2
# Drop loosely related fill-in results (same category or strong name overlap with top visual match)
IMAGE_SEARCH_STRICT_RELEVANCE=true
IMAGE_SEARCH_MIN_RELEVANCE_SCORE=14
IMAGE_SEARCH_MAX_SUPPLEMENT_ITEMS=8
IMAGE_SEARCH_VISUAL_EXPAND_CATALOG=false
IMAGE_SEARCH_VISUAL_EXPAND_SIMILAR=true
IMAGE_SEARCH_EMBEDDING_PRIMARY=true
IMAGE_SEARCH_METADATA_SEMANTIC=true
